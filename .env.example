# PlantDoctor RAG — Environment Configuration Template
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Firebase credentials.
# Option A (recommended): path to the service account JSON key file.
FIREBASE_SERVICE_ACCOUNT_FILE=./your-service-account-key.json

# Option B: the full service account JSON as an inline string.
# Use this when secrets are injected as environment variables (e.g. CI/CD).
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Generation backend
ACTIVE_GENERATION_BACKEND=GROK

GROK_API_KEY=your_grok_or_groq_api_key_here
XAI_API_URL=https://api.x.ai/v1
GROK_GENERATION_MODEL=grok-3-mini

COHERE_API_KEY=your_cohere_api_key_here
COHERE_GENERATION_MODEL=command-r-plus

# Generation defaults
INPUT_DEFAULT_MAX_CHARACTERS=4096
GENERATION_DEFAULT_MAX_TOKENS=1000
GENERATION_DEFAULT_TEMPERATURE=0.1

# Embedding model
# BAAI/bge-m3 supports Arabic and English.
ACTIVE_EMBEDDING_BACKEND=SENTENCE_TRANSFORMER
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_MODEL_SIZE=1024

# Summarization model
# facebook/bart-large-cnn is approximately 1.6 GB.
# Use sshleifer/distilbart-cnn-12-6 (approximately 250 MB) on smaller servers.
SUMMARIZATION_MODEL_ID=facebook/bart-large-cnn
SUMMARIZE_EVERY_N_MESSAGES=10

# Vector store
VECTOR_DB_BACKEND=QDRANT
VECTOR_DB_PATH=./storage/qdrant
VECTOR_DB_DISTANCE_METHOD=cosine
KNOWLEDGE_COLLECTION=plant_knowledge

# RAG retrieval
RAG_TOP_K=5

# File upload
FILE_ALLOWED_TYPES=["application/pdf", "text/plain"]
FILE_MAX_SIZE=20
UPLOAD_BASE_DIR=./storage/uploads

# Application
APP_NAME=plan-doctor-rag
APP_VERSION=1.0.0
